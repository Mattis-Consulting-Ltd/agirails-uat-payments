# =============================================================================
# AGIRAILS UAT Payments - Environment Variables
# Copy this file to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# -- Blockchain / RPC --
# Alchemy or Infura RPC URL for Base Sepolia testnet
BASE_SEPOLIA_RPC_URL=
# Private key for the deployer/bridge wallet (without 0x prefix)
DEPLOYER_PRIVATE_KEY=
# Basescan API key for contract verification
BASESCAN_API_KEY=

# -- IPFS --
# Pinata or Infura IPFS credentials
IPFS_PINNING_API_KEY=
IPFS_PINNING_API_SECRET=
IPFS_GATEWAY_URL=

# -- Middleware --
# API key for authenticating UAT harness requests to the middleware
MIDDLEWARE_API_KEY=
# Allowed CORS origin (defaults to http://localhost:3000)
CORS_ORIGIN=
# JWT secret for user authentication
JWT_SECRET=
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/agirails

# -- Notifications --
SLACK_WEBHOOK_URL=
NOTION_API_KEY=
NOTION_DATABASE_ID=

# -- Frontend --
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
